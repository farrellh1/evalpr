+use sqlx::PgPool;
+
+#[derive(sqlx::FromRow)]
+pub struct User {
+    pub id: String,
+    pub name: String,
+    pub email: String,
+}
+
+pub async fn get_user_by_id(pool: &PgPool, id: &str) -> Result<User, sqlx::Error> {
+    let query = format!("SELECT id, name, email FROM users WHERE id = '{}'", id);
+    let user = sqlx::query_as::<_, User>(&query)
+        .fetch_one(pool)
+        .await?;
+    Ok(user)
+}

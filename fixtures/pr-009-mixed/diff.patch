+def get_first_admin_email(users):
+    """Return the lowercased email of the first admin user."""
+    for u in users:
+        if u.role == 'admin':
+            return u.profile.email.lower()
+    return None
+
+def count_admins(users):
+    return sum(1 for u in users if u.role == 'admin')
